# ignore auto-generated files
**/.DS_Store
**/__pycache__
**/*.pyc
.pytest_cache/
.venv/
**/src.egg-info
animated_drawings.egg-info
animateddrawings.egg-info
*.log
logs/

# for the fixer app at examples/fixer_app
.parcel-cache/
node_modules

# ignore the .mar files
**/*.mar
torchserve/key_file.json
torchserve/model-store/

# ignore any vscode specific setting files
.vscode

# ignore any files created by following examples
**/log.txt
examples/garlic_out
**/*.mp4
**/*.gif
examples/video_app/outputs

# DO include .gifs used by the Readme
!media/*.gif

torchserve/logs/
